{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],   // adicione "DOM" se precisar ou apenas "ES2020"
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]           // aqui diz pro TypeScript reconhecer Node.js
  },
  "include": ["src/**/*"]
}